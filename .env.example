# X (Twitter) API 認証情報
# Developer Portal (https://developer.twitter.com/) で取得してください
# このファイルを .env にコピーして値を設定してください

X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# フォロー設定
DAILY_FOLLOW_LIMIT=200          # 1日のフォロー上限（デフォルト: 200）
FOLLOW_INTERVAL_SEC=18          # フォロー間隔（秒）レート制限対策
SEARCH_MAX_RESULTS=100          # 1回の検索で取得するツイート数（最大100）
