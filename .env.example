# X (Twitter) ログイン情報
X_USERNAME=あなたのXのID（@なし）またはメールアドレス
X_PASSWORD=あなたのXのパスワード
X_EMAIL=あなたのメールアドレス（2段階認証時に必要）

# フォロー設定
DAILY_FOLLOW_LIMIT=200     # 1日のフォロー上限（推奨: 200以下）
FOLLOW_DELAY_MIN=30        # フォロー間の最小待機秒数
FOLLOW_DELAY_MAX=90        # フォロー間の最大待機秒数

# ブラウザ設定
HEADLESS=false             # true: 画面なし / false: ブラウザを表示（初回はfalse推奨）
